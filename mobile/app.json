{
  "expo": {
    "name": "Shalom",
    "slug": "Shalom",
    "scheme": [
      "shalom"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#564beb"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-font",
      "expo-web-browser"
    ],
    "sdkVersion": "54.0.0",
    "extra": {
      "eas": {
        "projectId": "01c94c15-cac1-4d10-bf20-3f472f2fceb2"
      }
    },
    "ios": {
      "bundleIdentifier": "com.jasmine02.Shalom",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jasmine02.Shalom"
    },
    "cli": {
      "appVersionSource": "remote"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
