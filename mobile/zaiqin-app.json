{
  "expo": {
    "name": "Shalom",
    "slug": "Shalom",
    "scheme": ["shalom"],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#564beb"
    },
    "platforms": ["ios", "android", "web"],
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#564beb",
          "sounds": [],
          "mode": "development"
        }
      ]
    ],
    "sdkVersion": "54.0.0",
    "extra": {
      "eas": {
        "projectId": "65501d2b-f413-4930-bdac-abafafbeb317"
      }
    },
    "ios": {
      "bundleIdentifier": "com.jasmine02.Shalom",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jasmine02.Shalom",
      "permissions": ["POST_NOTIFICATIONS"],
      "googleServicesFile": "./google-services.json"
    },
    "cli": {
      "appVersionSource": "remote"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "zaiqin"
  }
}
