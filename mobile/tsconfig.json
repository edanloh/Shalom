{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "jsx": "react-jsx",
    "types": ["react", "node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@assets/*": ["./assets/*"],
      "@styles/*": ["./src/styles/*"],
      "@constants/*": ["./src/constants/*"]
    }
  },
  "include": ["src", "env.d.ts", "../web/src/pages/CoursePreview.tsx", "../web/src/pages/LessonDetail.tsx", "../web/src/pages/Notification.tsx", "../web/src/pages/QuizTaking.tsx"],
  "exclude": ["node_modules"],
  "extends": "expo/tsconfig.base"
}
