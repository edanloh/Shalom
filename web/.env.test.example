# Integration Test Environment Variables

# IMPORTANT: These should point to a SEPARATE test database instance
# DO NOT use your production or development database for integration tests!

# Supabase Test Database URL
VITE_SUPABASE_TEST_URL=https://your-test-project.supabase.co

# Supabase Test Database Anon Key
VITE_SUPABASE_TEST_ANON_KEY=your-test-anon-key-here

# Supabase Test Service Role Key (optional, for admin operations)
# WARNING: Keep this secret! Never commit the real key.
SUPABASE_TEST_SERVICE_KEY=your-test-service-role-key-here

# How to set up a test database:
# 1. Create a new Supabase project for testing
# 2. Run your database migrations on the test project
# 3. Copy the URL and keys from the test project settings
# 4. Copy this file to .env.test and fill in your values
# 5. Add .env.test to .gitignore (should already be there)
