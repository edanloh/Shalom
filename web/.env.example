# AWS Cognito Configuration
# Copy this file to .env and fill in your actual values
VITE_COGNITO_REGION=ap-southeast-1
VITE_COGNITO_CLIENT_ID=your-client-id-here
VITE_COGNITO_USER_POOL_ID=your-user-pool-id-here
VITE_AUTH_STORAGE_KEY=your-auth-storage-key-here

# API Configuration
VITE_API_BASE_URL=https://your-api-gateway-url.amazonaws.com/dev